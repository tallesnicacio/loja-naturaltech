# Copie para .env e ajuste conforme o evento.

# Porta do servidor local
PORT=3322

# Nome exibido no topo do PDV
EVENT_NAME=Natural Tech 2026 - True Source

# PIN para acessar a area de Admin (estoque, export, cancelamentos)
ADMIN_PIN=1234

# Backup automatico do banco (minutos). 0 desativa.
BACKUP_INTERVAL_MIN=5
# Quantos backups manter
BACKUP_KEEP=50

# ----- Impressao de comprovante termico -----
# Modo:
#   browser -> abre o dialogo de impressao no tablet/navegador
#   network -> servidor envia ESC/POS para impressora termica de rede (TCP 9100)
#   cups    -> servidor envia ESC/POS para impressora USB local registrada no CUPS
RECEIPT_MODE=cups
# Usado apenas quando RECEIPT_MODE=network (impressora termica na mesma rede)
PRINTER_HOST=
PRINTER_PORT=9100
# Usado apenas quando RECEIPT_MODE=cups (nome exato da fila: lpstat -p)
PRINTER_CUPS_NAME=
# Largura do papel em colunas (58mm ~ 32, 80mm ~ 48)
PRINTER_COLS=32

# Dados do emitente (aparecem no recibo)
STORE_NAME=TRUE
STORE_CNPJ=
